<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My ASP.NET Application</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>

<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-white fixed-top">
        <div class="container">
            <a href="@Url.Action("Index", "Home")">
                <img src="@Url.Content("~/Content/Images/logo.png")" style="width: 5rem" />
            </a>
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Toggle navigation" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between ms-5">
                <ul class="navbar-nav flex-grow-1 d-flex gap-4 ">
                    <li class="nav-item dropdown danhmuc p-0">
                        <button class="nav-link d-flex align-items-center gap-2 pe-0 bg-transparent border-0"                           
                           id="danhmucDropdown"
                           role="button"
                           aria-expanded="false">
                            <span class="navbar-toggler-icon small"></span>
                            <span class="text-black fs-6 text-uppercase">Danh mục</span>
                        </button>

                        <div class="dropdown-menu danhmuc-dropdown border-0 bg-white shadow-sm" aria-labelledby="danhmucDropdown">
                            <div class="w-100 d-flex justify-content-end align-items-center mb-4 px-4">
                                <a href=""
                                   class="d-flex align-items-center justify-content-between w-100 px-3 py-2 border-bottom text-decoration-none fs-6 fw-bold text-dark"
                                   style="border-color:#4b4a4a;">
                                    <span>Tìm kiếm</span>
                                    <img src="~/Content/Images/search.png" style="width: 9%" />
                                </a>
                            </div>
                            <div class="fs-5 fw-bold text-uppercase" style="padding-left: 40px">Danh mục sản phẩm</div>
                            <ul class="ps-2 pb-3">
                                @Html.Action("CategoriesMenu", "Product")
                            </ul>
                            <div class="fs-5 fw-bold text-uppercase" style="padding-left: 40px">Tìm kiếm theo</div>
                            <div class="fs-5 fw-bold" style="padding-left: 40px">Hãng</div>
                            <div style="padding-left: 40px" class="mb-3">
                                @Html.Action("BrandMenu", "Product")
                            </div>
                            <div class="fs-5 fw-bold" style="padding-left: 40px">Quốc gia</div>
                            <div style="padding-left: 40px" class="mb-3">
                                @Html.Action("OriginMenu", "Product")
                            </div>
                            <div class="fs-5 fw-bold" style="padding-left: 40px">Mức giá</div>
                            <div style="padding-left: 40px">
                                <div class="d-flex flex-wrap gap-2 mt-2">

                                    <a class="py-2 px-3 text-center btn btn-outline-primary fs-6"
                                       href="@Url.Action("Product", "Product", new { minPrice = 0, maxPrice = 100000 })">
                                        Dưới 100.000đ
                                    </a>

                                    <a class="py-2 px-3 text-center btn btn-outline-primary fs-6"
                                       href="@Url.Action("Product", "Product", new { minPrice = 100000, maxPrice = 300000 })">
                                        100.000đ - 300.000đ
                                    </a>

                                    <a class="py-2 px-3 text-center btn btn-outline-primary fs-6"
                                       href="@Url.Action("Product", "Product", new { minPrice = 300000, maxPrice = 500000 })">
                                        300.000đ - 500.000đ
                                    </a>

                                    <a class="py-2 px-3 text-center btn btn-outline-primary fs-6"
                                       href="@Url.Action("Product", "Product", new { minPrice = 500000, maxPrice = 1000000 })">
                                        500.000đ - 1.000.000đ
                                    </a>

                                    <a class="py-2 px-3 text-center btn btn-outline-primary fs-6"
                                       href="@Url.Action("Product", "Product", new { minPrice = 1000000, maxPrice = 99999999})">
                                        Trên 1.000.000đ
                                    </a>

                                </div>
                            </div>
                        </div>

                    </li>
                    <li class="nav-item dropdown dich-vu-dropdown">
                        <a class="nav-link text-black fs-6 dropdown-toggle  text-uppercase fs-6" href="#">
                            Dịch vụ
                        </a>
                        <ul class="dropdown-menu border-0 bg-light p-0">
                            <li class="dropdown-submenu">
                                <a class="dropdown-item dropdown-toggle py-2 fs-6 pe-5" href="#">
                                    Lớp học
                                </a>
                                <ul class="dropdown-menu border-0 bg-light">
                                    @Html.Action("ClassMenu", "Product")
                                </ul>
                            </li>

                            <li>
                                @if (Session["MaKH"] != null)
                                {
                                    <button class="dropdown-item py-2 fs-6 pe-5" id="btn_DangKyPT">Đăng ký PT</button>
                                }
                                else
                                {
                                    <button class="dropdown-item py-2 fs-6 pe-5"
                                            data-bs-toggle="modal" data-bs-target="#loginModal">
                                        Đăng ký PT
                                    </button>
                                }
                            </li>
                        </ul>
                    </li>

                    <li>@Html.ActionLink("Tìm lớp", "Index", "Class", new { area = "" }, new { @class = "nav-link text-black fs-6 text-uppercase" })</li>
                    <li>@Html.ActionLink("Gói tập", "GoiTap", "GoiTap", new { area = "" }, new { @class = "nav-link text-black fs-6 text-uppercase" })</li>
                </ul>
                <div class="w-50 d-flex justify-content-end">
                    <form class="d-flex w-100 justify-content-end gap-3" action="@Url.Action("Product", "Product")" method="post">
                        @Html.AntiForgeryToken()
                        <input class="form-control w-75 py-2" type="search" name="search" placeholder="Nhập thông tin cần tìm kiếm" aria-label="Search" required>
                        <button class="btn btn-primary py-2" type="submit">Tìm kiếm</button>
                    </form>
                </div>
            </div>
            <div class="d-flex align-items-center ms-3">
                @if (Session["TenKH"] == null)
                {
                    <button class="login-btn text-decoration-none d-flex justify-content-center border-0" style="background-color: #dddddd"  data-bs-toggle="modal" data-bs-target="#loginModal">
                        <span class="text-dark" style="font-size: 16px">Đăng nhập</span>
                        <img src="@Url.Content("~/Content/Images/user.png")" class="ms-2" style="width: 15%" />
                    </button>
                }
                else
                {
                    <div class="dropdown position-relative">
                        <a class="login-btn d-flex text-decoration-none justify-content-center align-items-center"
                           id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false" style="position: relative;">

                            <span class="text-dark fw-bold" style="font-size: 16px;">
                                @Session["TenKH"]
                            </span>

                            <img src="@Url.Content("~/Content/Images/user.png")" class="ms-2" style="width: 15%" />

                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger cartCount"
                                  style="@(Convert.ToInt32(Session["GioHang"]) > 0 ? "" : "display:none")">
                                @Convert.ToInt32(Session["GioHang"])
                            </span>
                        </a>

                        <ul class="dropdown-menu" aria-labelledby="dropdownUser">
                            <li><a class="dropdown-item" href="@Url.Action("Index", "Member")">Xem thông tin</a></li>
                            <li>
                                <a class="dropdown-item d-flex justify-content-between align-items-center"
                                   href="@Url.Action("ToCheckOut", "CartCheckout")">
                                    <span>Giỏ hàng</span>

                                    <span class="badge bg-danger rounded-pill cartCount"
                                          style="@(Convert.ToInt32(Session["GioHang"]) > 0 ? "" : "display:none")">
                                        @Convert.ToInt32(Session["GioHang"])
                                    </span>
                                </a>
                            </li>

                            <li><a class="dropdown-item" href="@Url.Action("Logout", "Account")">Đăng xuất</a></li>
                        </ul>
                    </div>

                }
            </div>

        </div>
    </nav>
    <div id="carouselExampleIndicators" class="carousel slide" data-bs-ride="carousel" style="margin-top: 80px">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>
        <div class="carousel-inner" style="height: 470px;">
            <div class="carousel-item active">
                <img src="@Url.Content("~/Content/Images/poster.jpeg")" class="d-block w-100 h-100 object-fit-cover" alt="...">
            </div>
            <div class="carousel-item">
                <img src="@Url.Content("~/Content/Images/poster1.jpeg")" class="d-block w-100 h-100 object-fit-cover" alt="...">
            </div>
            <div class="carousel-item">
                <img src="@Url.Content("~/Content/Images/poster2.jpeg")" class="d-block w-100 h-100 object-fit-cover" alt="...">
            </div>
        </div>
    </div>
    <div class="container-fluid bg-white p-0">
        @RenderBody()
    </div>
    <footer class="bg-white text-black py-5 mt-4">
        <div class="container">
            <div class="row justify-content-center mb-4">
                <div class="col-auto">
                    <a href="#" class="text-black text-decoration-none mx-3">Về The Gym</a>
                </div>
                <div class="col-auto">
                    <a href="#" class="text-black text-decoration-none mx-3">Hệ Thống Phòng Tập</a>
                </div>
                <div class="col-auto">
                    <a href="#" class="text-black text-decoration-none mx-3">Tuyển Dụng</a>
                </div>
                <div class="col-auto">
                    <a href="#" class="text-black text-decoration-none mx-3">Tin Tức</a>
                </div>
                <div class="col-auto">
                    <a href="#" class="text-black text-decoration-none mx-3">Liên Hệ</a>
                </div>
            </div>

            <div class="row justify-content-center mb-5">
                <div class="col-auto">
                    <a href="#" class="text-black text-decoration-none mx-3">Chính Sách Bảo Mật</a>
                </div>
                <div class="col-auto">
                    <a href="#" class="text-black text-decoration-none mx-3">Chăm Sóc Khách Hàng / Liên Hệ</a>
                </div>
                <div class="col-auto">
                    <a href="#" class="text-black text-decoration-none mx-3">Điều Khoản & Điều Kiện</a>
                </div>
            </div>
        </div>
        <div class="w-100">
            <hr />
            <div class="row justify-content-center mt-4 container mx-auto">
                <div class="col-auto">
                    <a href="#" class="text-black fs-5 mx-3"><i class="fab fa-facebook"></i></a>
                </div>
                <div class="col-auto">
                    <a href="#" class="text-black fs-5 mx-3"><i class="fab fa-instagram"></i></a>
                </div>
                <div class="col-auto">
                    <a href="#" class="text-black fs-5 mx-3"><i class="fab fa-tiktok"></i></a>
                </div>
                <div class="col-auto">
                    <a href="#" class="text-black fs-5 mx-3"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
        </div>
    </footer>
    <div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 w-75 mx-auto shadow-lg border-0 position-relative">
                <div class="mt-3 border-0 text-center w-100">
                    <h5 class="modal-title fw-bold text-primary text-center" id="loginModalLabel">THE-GYM MEMBER</h5>
                </div>
                <img src="@Url.Content("~/Content/Images/Logo.png")" class="mx-auto" style="width: 5rem" />
                <div class="modal-body text-center py-2">
                    <p class="mb-4 fw-semibold" style="font-size: 16px">
                        Vui lòng đăng nhập tài khoản <strong>The GYM</strong> để xem ưu đãi và thanh toán dễ dàng hơn.
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="@Url.Action("Login", "Account", new { returnUrl = Request.RawUrl })" class="btn btn-primary py-2 fw-semibold" style="width: 10rem">
                            Đăng nhập
                        </a>
                        <a href="@Url.Action("Register", "Account", new { returnUrl = Request.RawUrl })" class="btn btn-outline-primary py-2 fw-semibold" style="width: 10rem">
                            Đăng ký
                        </a>
                    </div>
                </div>
                <button type="button" class="btn-close position-absolute mt-2" data-bs-dismiss="modal" style="right: 0.7rem" aria-label="Đóng"></button>
            </div>
        </div>
    </div>
    <div id="DangKyPT" class="modal fade w-100">
        <div class="modal-dialog w-100">
            <div class="modal-content w-100" id="DangKyPT_body">
            </div>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["ThongBao"] != null)
    {
        <script>
        Swal.fire({
            icon: 'success',
            title: '@TempData["ThongBao"]',
            showConfirmButton: false,
            timer: 3000
        });

        </script>
    }
    @if (TempData["Error"] != null)
{
    <script>
        Swal.fire({
            icon: 'error',
            title: '@TempData["Error"]',
            showConfirmButton: false,
            timer: 3000
        });
    </script>
}

    <script>
        $('#btn_DangKyPT').click(function (e) {
            e.preventDefault(); // Ngăn chặn hành vi mặc định thẻ a/button

            $.ajax({
                url: '/GoiTap/DangKyPT', // Đảm bảo Controller tên là GoiTap, Action là DangKyPT
                type: 'GET',
                success: function (result) {
                    // Kiểm tra xem kết quả có phải là JSON báo lỗi (chưa đăng nhập) không
                    if (result.success === false && result.redirectUrl) {
                        // Nếu chưa đăng nhập -> Chuyển hướng sang trang Login
                        window.location.href = result.redirectUrl;
                    }
                    else {                        
                        $('#DangKyPT_body').html(result);
                        $('#DangKyPT').modal('show');
                    }
                },
                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi',
                        text: 'Không thể tải form đăng ký. Vui lòng thử lại sau!',
                        showConfirmButton: false,
                        timer: 2000
                    });
                }
            });
        });

        document.addEventListener('DOMContentLoaded', function () {
            const danhmucLink = document.getElementById('danhmucDropdown');
            const danhmucDropdown = document.querySelector('.danhmuc-dropdown');

            if (!danhmucLink || !danhmucDropdown) return;

            // Tắt positioning mặc định của Bootstrap
            danhmucLink.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();

                // Toggle class show
                if (danhmucDropdown.classList.contains('show')) {
                    danhmucDropdown.classList.remove('show');
                } else {
                    danhmucDropdown.classList.add('show');
                    // Reset inline styles do Bootstrap tạo ra
                    danhmucDropdown.style.position = '';
                    danhmucDropdown.style.inset = '';
                    danhmucDropdown.style.margin = '';
                    danhmucDropdown.style.transform = '';
                }
            });

            // Đóng menu khi click ra ngoài
            document.addEventListener('click', function (e) {
                if (!danhmucLink.contains(e.target) && !danhmucDropdown.contains(e.target)) {
                    danhmucDropdown.classList.remove('show');
                }
            });

            // Đóng menu khi nhấn ESC
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && danhmucDropdown.classList.contains('show')) {
                    danhmucDropdown.classList.remove('show');
                }
            });
        });
    </script>
</body>
</html>